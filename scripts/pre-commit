#!/bin/bash
# TaskRouter pre-commit hook — 提交前自动运行 ruff 检查
# 安装方式: bash scripts/setup-hooks.sh

set -e

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}[pre-commit] 运行 ruff check...${NC}"

# 只检查暂存的 Python 文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}[pre-commit] 无 Python 文件变更，跳过${NC}"
    exit 0
fi

# 运行 ruff check（与 CI 一致的规则）
if ! echo "$STAGED_FILES" | xargs ruff check --select E,F,W --ignore E501,E402,F541; then
    echo ""
    echo -e "${RED}[pre-commit] ruff 检查失败！请修复后再提交。${NC}"
    echo -e "${RED}提示: 运行 'ruff check scripts/ --select E,F,W --ignore E501,E402,F541 --fix' 自动修复${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-commit] ruff 检查通过 ✓${NC}"
